# =============================================================================
# Operating System Files
# =============================================================================
.DS_Store

# Editor swap/temp/log files
*.swp
*.swo
*~
*.log

# =============================================================================
# IDE / Editor
# =============================================================================
# JetBrains (IntelliJ IDEA / WebStorm / etc.)
.idea/
*.iml
*.ipr
*.iws
out/


# Cursor (AI editor based on VS Code)
.cursor/

# Claude Code local config
.claude/

# =============================================================================
# Environment & Secrets (server/.env.example and web/.env.example are tracked)
# =============================================================================
.env
.env.*
!.env.example
!.env.*.example

# SSL / TLS / keystore
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.jks
*.keystore

# =============================================================================
# Build Outputs (root-level only — server/ and web/ each have their own .gitignore)
# =============================================================================
build/
dist/
out/
bin/
target/

# =============================================================================
# Tooling / Cache
# =============================================================================
.codegraph/
.superpowers/

# =============================================================================
# Test / Coverage
# =============================================================================
coverage/
.nyc_output/
*.lcov
junit*.xml
test-results/
playwright-report/
.playwright/
blob-report/
playwright/.cache/
verification/report/

# =============================================================================
# Runtime / Data
# =============================================================================
data/
*.pid
*.pid.lock
*.seed
*.tgz


# =============================================================================
# OS-specific / Misc
# =============================================================================
*.tmp
*.bak
*.orig
*.rej
.local
