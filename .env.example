# ==================== 数据库配置 ====================
# 容器内默认值，host 应为 docker compose service name
DB_HOST=mysql
DB_PORT=3306
DB_NAME=site-guard
DB_USER=root
DB_PASSWORD=root123456

# ==================== JWT 配置 ====================
# JWT 密钥（生产环境请使用强随机字符串，≥ 32 字符 / 256 位）
# HS256 算法最低要求 256 位；建议使用以下命令生成: openssl rand -base64 32
JWT_SECRET=ChangeThisSecretKeyInProduction_7gK9xQ2mLp8Zr4VnT6cW1yHs3DfA0bJu

# ==================== 管理员账号 ====================
# 首次部署默认 admin/admin，生产环境必须修改
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ==================== 日志配置 ====================
# 全局日志级别：ERROR / WARN / INFO / DEBUG
LOG_LEVEL=DEBUG

# ==================== JVM 配置 ====================
# JVM 内存参数（根据实际情况调整）
JAVA_OPTS=-Xms256m -Xmx512m