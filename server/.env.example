# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ai-courseware
DB_USER=root
DB_PASSWORD=

# ==================== 管理员账号 ====================
# 首次部署默认 admin/admin，生产环境必须修改
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ==================== 日志配置 ====================
# 全局日志级别：ERROR / WARN / INFO / DEBUG
LOG_LEVEL=INFO